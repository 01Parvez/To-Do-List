{
    "info": {
        "_postman_id": "lib-mgmt-v1",
        "name": "Library Management System API",
        "description": "Complete API test collection for the Library Management System\n\nSetup:\n1. Run Spring Boot backend on port 8080\n2. Use 'Login' request first and copy the token\n3. The token auto-sets the {{jwt}} variable",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080/api",
            "type": "string"
        },
        {
            "key": "jwt",
            "value": "",
            "type": "string"
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{jwt}}",
                "type": "string"
            }
        ]
    },
    "item": [
        {
            "name": "1. Authentication",
            "item": [
                {
                    "name": "Register User",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
                        }
                    }
                },
                {
                    "name": "Login (Admin)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var response = pm.response.json();",
                                    "pm.collectionVariables.set('jwt', response.token);",
                                    "pm.test('Login successful', () => pm.response.to.have.status(200));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
                        }
                    }
                },
                {
                    "name": "Login (User)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var response = pm.response.json();",
                                    "pm.collectionVariables.set('jwt', response.token);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"user\",\n  \"password\": \"user123\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Books",
            "item": [
                {
                    "name": "Get All Books",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/books?page=0&size=10"
                    }
                },
                {
                    "name": "Search Books",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/books/search?keyword=harry"
                    }
                },
                {
                    "name": "Get Book by ID",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/books/1"
                    }
                },
                {
                    "name": "Add Book (Admin)",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/books",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Spring Boot in Action\",\n  \"author\": \"Craig Walls\",\n  \"isbn\": \"978-1-617-29269-8\",\n  \"category\": \"Technology\",\n  \"publisher\": \"Manning\",\n  \"publicationYear\": 2016,\n  \"totalCopies\": 3\n}"
                        }
                    }
                },
                {
                    "name": "Update Book (Admin)",
                    "request": {
                        "method": "PUT",
                        "url": "{{base_url}}/books/1",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"The Great Gatsby (Updated)\",\n  \"author\": \"F. Scott Fitzgerald\",\n  \"totalCopies\": 6\n}"
                        }
                    }
                },
                {
                    "name": "Delete Book (Admin)",
                    "request": {
                        "method": "DELETE",
                        "url": "{{base_url}}/books/10"
                    }
                }
            ]
        },
        {
            "name": "3. Members (Admin)",
            "item": [
                {
                    "name": "Get All Members",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/members"
                    }
                },
                {
                    "name": "Create Member",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/members",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+919876543210\",\n  \"membershipDate\": \"2024-01-15\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "4. Borrowing",
            "item": [
                {
                    "name": "Borrow Book",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/borrow",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"bookId\": 1\n}"
                        }
                    }
                },
                {
                    "name": "Return Book",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/borrow/return/1"
                    }
                },
                {
                    "name": "My Active Borrows",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/borrow/my-borrows"
                    }
                },
                {
                    "name": "User Borrow History",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/borrow/user/1"
                    }
                },
                {
                    "name": "Get Overdue (Admin)",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/borrow/overdue"
                    }
                }
            ]
        },
        {
            "name": "5. Dashboard",
            "item": [
                {
                    "name": "Admin Dashboard",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/dashboard/admin"
                    }
                },
                {
                    "name": "User Dashboard",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/dashboard/user"
                    }
                }
            ]
        }
    ]
}